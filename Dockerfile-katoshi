FROM python:3.9-slim

WORKDIR /app

RUN pip install --upgrade pip

COPY requirements-katoshi.txt .

RUN pip install --no-cache-dir -r requirements-katoshi.txt

COPY strategy_katoshi_fng_ma_buyer.py .

RUN adduser --disabled-password --gecos "" appuser && chown -R appuser /app
USER appuser

HEALTHCHECK --interval=60s --timeout=10s --start-period=30s --retries=3 \
    CMD python -c "import schedule; print('ok')" || exit 1

CMD ["python", "-u", "strategy_katoshi_fng_ma_buyer.py"]
